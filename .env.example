# Copy this file to `.env` and fill in your server details.
# All variables except MC_HOST/MC_PORT/MC_USERNAME are optional.

# --- Required ---
MC_HOST=your-server.aternos.me
MC_PORT=12345
MC_USERNAME=AFKBot

# --- Auth / version ---
MC_AUTH=offline           # offline (Aternos cracked) or microsoft
MC_VERSION=false          # false = auto-detect, or pin e.g. 1.20.4

# --- Resource controls ---
MC_VIEW_DISTANCE=tiny     # tiny | short | normal | far
BOT_CHUNK_PRUNE_INTERVAL_MS=30000
BOT_CHUNK_PRUNE_RADIUS=2
BOT_MEMORY_GC_THRESHOLD_MB=200

# --- Anti-AFK / chat ---
BOT_ANTI_AFK_INTERVAL_MS=20000
# Pipe-separated chat messages, e.g. "hi|/afk|still here"
BOT_CHAT_MESSAGES=
BOT_CHAT_INTERVAL_MS=60000

# --- Auto-eat ---
BOT_AUTO_EAT=true
BOT_AUTO_EAT_THRESHOLD=17
BOT_AUTO_EAT_PRIORITY=saturation   # saturation | foodPoints

# --- Reconnect ---
BOT_RECONNECT_MIN_MS=10000
BOT_RECONNECT_MAX_MS=120000
